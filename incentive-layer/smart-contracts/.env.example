# Example .env file for smart contracts
# Copy this to .env and fill in your values

# Wallet private key (DO NOT COMMIT THIS FILE)
PRIVATE_KEY=your_private_key_here

# Polygon RPC URLs (you can use public RPCs or get from Alchemy/Infura)
MUMBAI_RPC=https://rpc-mumbai.maticvigil.com
POLYGON_RPC=https://polygon-rpc.com

# PolygonScan API key for contract verification
# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# CoinMarketCap API key for gas reporting (optional)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# IPFS/Kubo node URL
KUBO_API_URL=http://localhost:5001

# Database connection (PostgreSQL for indexing)
DATABASE_URL=postgresql://user:password@localhost:5432/incentive_layer

# Redis for caching
REDIS_URL=redis://localhost:6379
