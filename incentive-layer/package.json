{
  "name": "@kubo/incentive-layer",
  "version": "0.1.0",
  "description": "Incentive layer for Kubo/IPFS",
  "private": true,
  "scripts": {
    "test:e2e": "cd test/e2e && npm install && npx ts-node run-e2e.ts",
    "e2e:up": "cd test/e2e && docker-compose up -d",
    "e2e:down": "cd test/e2e && docker-compose down",
    "e2e:logs": "cd test/e2e && docker-compose logs -f",
    "build:all": "npm run build --workspaces",
    "install:all": "npm install --workspaces"
  },
  "workspaces": [
    "api/rest-api",
    "services/*",
    "smart-contracts",
    "cli"
  ],
  "devDependencies": {
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
