PROOF_VERIFIER_CONTRACT=0xB74fA7fD8E6EAd93FBF081dC26abe8321549E7de
MARKETPLACE_CONTRACT=0xc19c805eAfeAe35839D4b27113ec2ca91E8dCa61

# --- Service Configuration ---
# Incentive Layer API URL
API_URL=http://api.incentivelayer.io

# --- IPFS Configuration (Optional) ---
