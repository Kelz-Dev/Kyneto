# --- Provider Configuration ---

# Your Polygon Wallet Private Key (Required for signing heartbeats and proofs)
PRIVATE_KEY=0x...

# Polygon RPC URL (e.g., Alchemy, Infura, or public node)
RPC_URL=https://rpc-amoy.polygon.technology

# --- Contract Addresses ---
# These are required for the provider-cli and provider-daemon
REGISTRY_CONTRACT=0xd9145CCE52D386f254917e481eB44e9943F39138
TOKEN_CONTRACT=0xAc526414a2f1c912DFd888Aeb676E72bA78F73Ff
PLEDGES_CONTRACT=0xd8b934580fcE35a11B58C6D73aDeE468a2833fa8
PAYMENTS_CONTRACT=0xD7ACd2a9FD159E69Bb102A1ca21C9a3e3A5F771B
PROOF_VERIFIER_CONTRACT=0x1f56644399e89F25fd8F4837eA88D950a0497d05
MARKETPLACE_CONTRACT=0xf8e81D47203A594245E36C48e151709F0C19fBe8

# --- Service Configuration ---
# Incentive Layer API URL
API_URL=http://api.incentivelayer.io

# --- IPFS Configuration (Optional) ---
# The stack includes a local IPFS node, but you can point to an existing one
KUBO_API_URL=http://ipfs:5001
